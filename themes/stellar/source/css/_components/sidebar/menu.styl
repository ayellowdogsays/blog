.nav-area .menu
  display: grid
  margin-bottom: 8px
  box-shadow: $boxshadow-inset-block
  padding: 2px
  border: 1px solid var(--block-border)
  border-radius: $border-bar
  background: var(--block)
  grid-template-columns: repeat(hexo-config('menubar.columns'), 1fr)
  grid-gap: 2px
  overflow: hidden

  &::-webkit-scrollbar,
  &::-webkit-scrollbar-track-piece,
  &::-webkit-scrollbar-thumb
    display: none

  .nav-item
    box-sizing: border-box
    width: 100%
    min-height: 38px
    font-size: $fs-15
    font-weight: 500
    color: var(--text-p3)
    text-align: center
    position: relative
    display: flex
    flex-direction: column
    align-items: center
    justify-content: center
    border-radius: $border-bar
    transition: background 0.2s ease, color 0.2s ease

    img, svg
      height: 26px
      object-fit: contain
      filter: grayscale(100%) brightness(0.7) opacity(0.7)
      transition: filter 0.2s ease

    span
      text-overflow: ellipsis
      word-break: keep-all
      white-space: nowrap
      overflow: hidden
      max-width: 100%

    &.active, 
    &:hover
      color: var(--text-p1)
      background: var(--card)
      img, svg
        filter: unset

    &.active::after
      content: ''
      position: absolute
      width: 16px
      height: 2px
      left: 50%
      transform: translateX(-50%)
      border-radius: 2px
      bottom: 3px
      background: currentColor