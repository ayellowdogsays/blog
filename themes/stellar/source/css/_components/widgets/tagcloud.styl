.widget-wrapper.tagcloud .widget-body
  border-radius: $border-card
  padding: 16px // 稍微增加内边距，让内容不贴边
  background: var(--alpha50)
  display: flex // 使用 Flexbox 布局
  flex-wrap: wrap // 允许标签换行
  gap: 8px // 标签之间的统一间距，告别 margin 的复杂计算

  a  
    word-break: break-word
    color: var(--text-p2)
    line-height: 1.5
    font-size: 0.875em // 稍微缩小字号，更像“标签”
    padding: 4px 12px // 增加内边距，让标签有“胶囊”感
    border-radius: 16px // 胶囊圆角
    background: var(--block) // 增加淡淡的背景色，区分层次
    border: 1px solid var(--block-border) // 增加边框，更有质感
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1) // 丝滑过渡
    white-space: nowrap // 防止单个标签内的文字换行
    
    // 悬停微交互
    &:hover
      color: var(--text-p1) // 悬停时文字颜色加深
      background: var(--card) // 悬停时背景色加深
      border-color: $color-hover // 边框变成主题高亮色
      transform: translateY(-2px) // 悬停时轻微上浮
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05) // 增加微阴影