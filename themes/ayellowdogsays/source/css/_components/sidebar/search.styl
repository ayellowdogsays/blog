/* Search Wrapper - Popup Version */
.search-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  background: var(--site-bg);
  padding: 1rem;
  box-sizing: border-box;
  display: none;
  opacity: 0;
  transform: translateY(-20px);
  transition: opacity 0.3s ease, transform 0.3s ease;
  backdrop-filter: blur(5px);
  
  &.active {
    display: block;
    opacity: 1;
    transform: translateY(0);
    animation: searchFadeIn 0.3s ease forwards;
  }

  > .search-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--block-border);
  }

  > .search-form {
    position: relative;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    background: var(--block);
    border-radius: var(--border-card);
    padding: 0.5rem 1rem;
    box-shadow: var(--boxshadow-card);
    transition: all 0.3s ease;

    &:focus-within {
      box-shadow: 0 0 0 2px var(--color-theme);
      transform: translateY(-2px);
    }
  }

  .search-input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 1rem;
    padding: 0.75rem 0;
    color: var(--text-p1);
    outline: none;

    &::placeholder {
      color: var(--text-p3);
      opacity: 0.7;
    }
  }

  .search-close {
    background: none;
    border: none;
    color: var(--text-p3);
    font-size: 1.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0.5rem;

    &:hover {
      color: var(--color-theme);
      transform: rotate(90deg);
    }
  }

  #search-result {
    max-height: 70vh;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--color-theme) var(--block);

    &::-webkit-scrollbar {
      width: 6px;
    }

    &::-webkit-scrollbar-thumb {
      background-color: var(--color-theme);
      border-radius: 3px;
    }

    &::-webkit-scrollbar-track {
      background: var(--block);
    }
  }

  .search-result-item {
    padding: 1rem;
    margin-bottom: 0.75rem;
    background: var(--block);
    border-radius: var(--border-card);
    transition: all 0.3s ease;
    box-shadow: var(--boxshadow-card);

    &:hover {
      transform: translateX(5px);
      background: var(--card);
    }

    .search-result-title {
      color: var(--text-p1);
      font-weight: bold;
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .search-result-content {
      color: var(--text-p3);
      font-size: 0.9rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .search-keyword {
      color: var(--color-theme);
      font-weight: bold;
      background: rgba(var(--color-theme-rgb), 0.1);
      padding: 0 2px;
      border-radius: 2px;
    }
  }

  .search-no-result {
    text-align: center;
    padding: 2rem;
    color: var(--text-p3);
    font-size: 1rem;
  }
}

/* Animations */
@keyframes searchFadeIn {
  from {
    opacity: 0;
    transform: translateY(-20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Mobile Responsiveness */
@media (max-width: 768px) {
  .search-wrapper {
    padding: 1rem 0.5rem;
    
    .search-form {
      padding: 0.5rem;
    }
    
    .search-input {
      font-size: 0.9rem;
    }
    
    .search-result-item {
      padding: 0.75rem;
    }
  }
}
