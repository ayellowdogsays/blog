/* Horizontal Layout Modifications */
#search-result {
  max-height: 60vh;
  overflow-x: auto;
  overflow-y: hidden;
  scrollbar-width: thin;
  scrollbar-color: var(--color-theme) var(--block);
  display: flex;
  flex-wrap: nowrap;
  gap: 12px;
  padding-bottom: 12px;
}

#search-result::-webkit-scrollbar {
  height: 6px;
}

#search-result::-webkit-scrollbar-thumb {
  background-color: var(--color-theme);
  border-radius: 3px;
}

#search-result::-webkit-scrollbar-track {
  background: var(--block);
}

.search-result-list {
  display: flex;
  flex-wrap: nowrap;
  gap: 12px;
  padding: 0 8px;
  margin: 0;
}

.search-result-list li {
  flex: 0 0 auto;
  width: 280px; /* Fixed width for each card */
}

.search-result-list li a {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 120px; /* Minimum height for cards */
  padding: 1rem;
  transition: all 0.3s ease;
}

.search-result-list li+li {
  margin-top: 0; /* Remove vertical margin */
}

.search-result-title {
  font-size: var(--fs-14);
  margin-bottom: 8px;
}

.search-result-content {
  -webkit-line-clamp: 3; /* Show more lines in horizontal layout */
  flex-grow: 1;
}

/* Mobile Responsiveness Adjustments */
@media screen and (max-width: 768px) {
  #search-result {
    max-height: 65vh;
    gap: 8px;
  }
  
  .search-result-list li {
    width: 240px; /* Slightly narrower cards on mobile */
  }
  
  .search-result-title {
    font-size: var(--fs-13);
  }
  
  .search-result-content {
    font-size: var(--fs-12);
  }
}

/* Keep all other existing styles the same */
